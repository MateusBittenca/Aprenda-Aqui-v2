# Copie para .env na raiz do repositório (desenvolvimento local)

# MySQL — docker compose up ou instância local
DATABASE_URL="mysql://root:root@localhost:3306/aprenda_aqui"

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# URL do frontend (local ou Railway do serviço web)
NEXTAUTH_URL="http://localhost:3000"

# URL pública da API Express (local ou Railway do serviço api)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Opcional local — Railway injeta PORT automaticamente
# API_PORT=4000
