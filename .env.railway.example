# Copie para .env.railway na raiz (arquivo ignorado pelo Git).
# Railway → MySQL → Settings → Networking → endereço público (TCP Proxy).

# URL pública do MySQL (não use mysql.railway.internal)
PRODUCTION_DATABASE_URL="mysql://root:SUA_SENHA@HOST.proxy.rlwy.net:PORTA/railway"

# Opcional — banco local como origem do sync-tracks
