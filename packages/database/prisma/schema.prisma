generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum LessonType {
  QUIZ
  CODE
}

enum LeagueTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ActivityType {
  LESSON_COMPLETED
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FRIEND_ACTIVITY
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  emailVerified   DateTime? @map("email_verified")
  image           String?
  passwordHash    String?   @map("password_hash")
  xpTotal              Int       @default(0) @map("xp_total")
  gems                 Int       @default(0)
  streakAtual          Int       @default(0) @map("streak_atual")
  ultimaAtividade      DateTime? @map("ultima_atividade")
  activeTitleKey       String    @default("iniciante") @map("active_title_key")
  lastCelebratedLevel  Int       @default(1) @map("last_celebrated_level")
  dailyRewardNextDay   Int       @default(1) @map("daily_reward_next_day")
  dailyRewardLastClaim DateTime? @map("daily_reward_last_claim")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  accounts            Account[]
  sessions            Session[]
  progress            UserProgress[]
  leaderboard         LeaderboardEntry[]
  friendshipsSent     Friendship[]     @relation("FriendshipRequester")
  friendshipsReceived Friendship[]     @relation("FriendshipAddressee")
  activities          ActivityEvent[]
  notifications       Notification[] @relation("NotificationRecipient")
  notificationsSent   Notification[] @relation("NotificationActor")
  chestClaims         UserChestClaim[]
  titleUnlocks        UserTitleUnlock[]

  @@map("users")
}

model UserTitleUnlock {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  titleKey   String   @map("title_key")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, titleKey])
  @@map("user_title_unlocks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Track {
  id             String   @id @default(cuid())
  title          String
  description    String   @db.Text
  icon           String
  slug           String   @unique
  order          Int      @default(0)
  colorPrimary   String   @default("#58CC02") @map("color_primary")
  colorDark      String   @default("#1f5100") @map("color_dark")
  colorLight     String   @default("#87fe45") @map("color_light")
  colorMuted     String   @default("#2b6c00") @map("color_muted")
  colorOnPrimary String   @default("#ffffff") @map("color_on_primary")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  units   Unit[]
  lessons Lesson[]
  chests  TrackChest[]

  @@map("tracks")
}

model Unit {
  id          String  @id @default(cuid())
  trackId     String  @map("track_id")
  title       String
  description String? @db.Text
  order       Int     @default(0)
  pathOffset  Int     @default(0) @map("path_offset")

  track   Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("units")
}

model Lesson {
  id        String     @id @default(cuid())
  trackId   String     @map("track_id")
  unitId    String?    @map("unit_id")
  title     String
  type      LessonType
  content   Json
  solution  Json?
  order     Int        @default(0)
  xpReward   Int @default(10) @map("xp_reward")
  gemsReward Int @default(5) @map("gems_reward")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  track         Track          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  unit          Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  progress      UserProgress[]
  chestsAfter   TrackChest[]   @relation("ChestAfterLesson")

  @@map("lessons")
}

model TrackChest {
  id            String   @id @default(cuid())
  trackId       String   @map("track_id")
  afterLessonId String   @map("after_lesson_id")
  title         String   @default("Baú de recompensas")
  xpReward      Int      @default(25) @map("xp_reward")
  gemsReward    Int      @default(10) @map("gems_reward")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")

  track       Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  afterLesson Lesson           @relation("ChestAfterLesson", fields: [afterLessonId], references: [id], onDelete: Cascade)
  claims      UserChestClaim[]

  @@unique([trackId, afterLessonId])
  @@map("track_chests")
}

model UserChestClaim {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  chestId    String   @map("chest_id")
  xpEarned   Int      @map("xp_earned")
  gemsEarned Int      @map("gems_earned")
  claimedAt  DateTime @default(now()) @map("claimed_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  chest TrackChest @relation(fields: [chestId], references: [id], onDelete: Cascade)

  @@unique([userId, chestId])
  @@map("user_chest_claims")
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  lessonId    String   @map("lesson_id")
  completed   Boolean  @default(true)
  xpEarned    Int      @default(0) @map("xp_earned")
  completedAt DateTime @default(now()) @map("completed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("user_progress")
}

model LeaderboardEntry {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  weekStart DateTime   @map("week_start") @db.Date
  xpWeekly  Int        @default(0) @map("xp_weekly")
  league    LeagueTier @default(BRONZE)
  rank      Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart, xpWeekly(sort: Desc)])
  @@map("leaderboard")
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String           @map("requester_id")
  addresseeId String           @map("addressee_id")
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friendships")
}

model ActivityEvent {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  type      ActivityType
  metadata  Json
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("activity_events")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  actorId   String?          @map("actor_id")
  type      NotificationType
  read      Boolean          @default(false)
  metadata  Json
  createdAt DateTime         @default(now()) @map("created_at")

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}
